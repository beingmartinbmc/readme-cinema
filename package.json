{
  "name": "readme-cinema",
  "version": "1.1.0",
  "description": "Transform your README files into cinematic terminal experiences with ASCII art, typewriter effects, and dramatic transitions",
  "main": "index.js",
  "type": "module",
  "bin": {
    "readme-cinema": "./bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node ./bin/cli.js",
    "dev": "node ./bin/cli.js README.md --color neon --progress --instant --no-clear",
    "demo": "node quick-demo.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --runInBand --watchAll=false",
    "lint": "eslint .",
    "build": "node ./bin/cli.js --help >/dev/null",
    "prepublishOnly": "npm run lint && npm run test:ci && npm run build"
  },
  "keywords": [
    "cli",
    "readme",
    "terminal",
    "ascii",
    "cinematic",
    "typewriter",
    "hacker",
    "markdown"
  ],
  "author": "Ankit Sharma <ankit.sharma199803@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beingmartinbmc/readme-cinema.git"
  },
  "bugs": {
    "url": "https://github.com/beingmartinbmc/readme-cinema/issues"
  },
  "homepage": "https://github.com/beingmartinbmc/readme-cinema#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "figlet": "^1.11.0",
    "fs-extra": "^11.3.4",
    "marked": "^18.0.2"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "jest": "^29.7.0"
  }
}
