{
  "name": "readme-cinema",
  "version": "1.0.0",
  "description": "Transform your README files into cinematic terminal experiences with ASCII art, typewriter effects, and dramatic transitions",
  "main": "index.js",
  "bin": {
    "readme-cinema": "./bin/cli.js"
  },
  "scripts": {
    "start": "node ./bin/cli.js",
    "dev": "node ./bin/cli.js README.md --color neon --progress",
    "demo": "node quick-demo.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "echo \"No linter configured yet\"",
    "build": "echo \"No build step needed\"",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "cli",
    "readme",
    "terminal",
    "ascii",
    "cinematic",
    "typewriter",
    "hacker",
    "markdown"
  ],
  "author": "Ankit Sharma <ankit.sharma199803@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beingmartinbmc/readme-cinema.git"
  },
  "bugs": {
    "url": "https://github.com/beingmartinbmc/readme-cinema/issues"
  },
  "homepage": "https://github.com/beingmartinbmc/readme-cinema#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "figlet": "^1.6.0",
    "fs-extra": "^11.1.1",
    "marked": "^9.1.6",
    "ora": "^7.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "type": "module"
}
